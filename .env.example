# Production server
HOST=0.0.0.0
PORT=4000

# PostgreSQL + Prisma
DATABASE_URL=postgresql://maharshwe_pos:change_this_password@127.0.0.1:5432/maharshwe_pos?schema=public

# PostgreSQL backup and recovery
BACKUP_DIR=/var/backups/mahar-pos/postgres
BACKUP_RETENTION_DAYS=14
BACKUP_STALE_HOURS=30
BACKUP_MIN_BYTES=1024
# Optional disposable database used only by scripts/postgres-restore-verify.sh
# Never set this to the production DATABASE_URL.
RESTORE_VERIFY_DATABASE_URL=

# API security token used by POS settings / protected endpoints
POS_API_TOKEN=maharshwe123

# Server-side login security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
CORS_ORIGINS=https://maharshwe.shop,https://app.maharshwe.shop,https://admin.maharshwe.shop,http://localhost:5173
AUTH_REQUIRED=false

# Safe development seed passwords only. Change on VPS.
SEED_SUPER_ADMIN_PASSWORD=superadmin123
SEED_SHOP_ADMIN_PASSWORD=admin1234
SEED_CASHIER_PASSWORD=cashier1234

# Real Telegram Login + Daily Report
TELEGRAM_BOT_TOKEN=
# Optional alias; server falls back to this if TELEGRAM_BOT_TOKEN is empty.
TELEGRAM_API_KEY=
TELEGRAM_ADMIN_CHAT_ID=
# Optional Google Apps Script endpoint used to mirror push/renew records to a Sheet.
TELEGRAM_SHEET_API_URL=

# Google Sheet live sync Apps Script Web App
GOOGLE_SHEET_WEB_APP_URL=
GOOGLE_SHEET_SYNC_SECRET=

# Optional accounting Daily Report sheet endpoint
ACCOUNTING_DAILY_WEB_APP_URL=

# Repair Tracking Apps Script Web App URL for voucher lookup.
# Existing IDs use the current prefix format such as MS0551, AC0001 or TL0001.
MAHAR_SHWE_SHOP_SLUG=maharshwe-mobile
REPAIR_TRACKING_WEB_APP_URL=
REPAIR_TRACKING_API_KEY=
REPAIR_API_TIMEOUT_MS=12000

# Firebase Cloud Messaging (public web config; safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAK8Kcd7J5dShAqn2QlJmAZFeJRVg1mfOw
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=maharshweonlinevpn.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=maharshweonlinevpn
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=maharshweonlinevpn.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=648689584934
NEXT_PUBLIC_FIREBASE_APP_ID=1:648689584934:web:47f1ee30f86090fb32cfe7
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-DW2DHE0211
