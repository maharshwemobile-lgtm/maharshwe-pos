# Production server
HOST=0.0.0.0
PORT=4000

# PostgreSQL + Prisma
DATABASE_URL=postgresql://maharshwe_pos:change_this_password@127.0.0.1:5432/maharshwe_pos?schema=public

# API security token used by POS settings / protected endpoints
POS_API_TOKEN=maharshwe123

# Server-side login security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
CORS_ORIGINS=https://maharshwe.shop,https://app.maharshwe.shop,https://admin.maharshwe.shop,http://localhost:5173
AUTH_REQUIRED=false

# Safe development seed passwords only. Change on VPS.
SEED_SUPER_ADMIN_PASSWORD=superadmin123
SEED_SHOP_ADMIN_PASSWORD=admin1234
SEED_CASHIER_PASSWORD=cashier1234

# Real Telegram Login + Daily Report
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Optional report-sheet Apps Script endpoint for full POS syncPOS payloads
GOOGLE_SHEET_WEB_APP_URL=

# Optional accounting Daily Report sheet endpoint
ACCOUNTING_DAILY_WEB_APP_URL=

# Repair Tracking Apps Script Web App URL for voucher lookup.
# This must point to the 14EfYo... repair tracking script deployment.
REPAIR_TRACKING_WEB_APP_URL=
