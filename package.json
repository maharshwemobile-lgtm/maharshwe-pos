{
  "name": "mahar-pos-webapp-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:api": "nodemon --watch server --ext js --ignore data/** --ignore server/*.json server/api-connected.js",
    "start": "node server/api-connected.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "5.4.11",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "lucide-react": "0.468.0",
    "concurrently": "9.2.1",
    "nodemon": "3.1.10",
    "express": "4.21.2",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "jsonwebtoken": "9.0.2",
    "bcryptjs": "2.4.3",
    "sqlite": "5.1.1",
    "sqlite3": "5.1.7"
  },
  "devDependencies": {}
}
